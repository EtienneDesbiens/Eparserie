# GroceryBot Configuration

# Location
POSTAL_CODE=J1H2B4

# Email (Mailersend SMTP)
# MAILERSEND_EMAIL should be your SMTP username from Mailersend Settings > SMTP
# MAILERSEND_API_KEY should be your SMTP password from Mailersend Settings > SMTP
EMAIL_FROM=noreply@grocerybot.local
EMAIL_RECIPIENT=your-email@example.com
MAILERSEND_EMAIL=your-smtp-username
MAILERSEND_API_KEY=your-smtp-password

# API Keys
SPOONACULAR_API_KEY=your_spoonacular_key_here

# Settings
MAX_DEALS_PER_STORE=10
